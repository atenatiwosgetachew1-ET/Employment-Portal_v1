# Django
SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (PostgreSQL) — required; there is no SQLite fallback
# Example: createdb employment_portal
DB_NAME=employment_portal
DB_USER=postgres
# Required on most installs: password for the PostgreSQL user
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
# Optional: DB_SSLMODE=require

# Email (Gmail SMTP)
# 1) Enable 2-Step Verification on the Google account.
# 2) Create an App Password: https://myaccount.google.com/apppasswords → Mail / Other → copy 16 chars.
# 3) Put it in EMAIL_HOST_PASSWORD (no spaces). DEFAULT_FROM_EMAIL must match EMAIL_HOST_USER for Gmail.
# If EMAIL_HOST_PASSWORD is empty, Django uses the console backend — nothing is delivered, only printed in the terminal.
EMAIL_HOST_USER=qedamaitechnologies@gmail.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=qedamaitechnologies@gmail.com
# Optional: EMAIL_PORT=587  EMAIL_USE_TLS=true  EMAIL_USE_SSL=false

# Links in verification / password-reset emails (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Production: set true when serving over HTTPS
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=3600
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=false

# Sign in with Google — create an OAuth 2.0 "Web client" in Google Cloud Console and paste the client ID
# (same value in frontend as VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Frontend only (Vite): copy of GOOGLE_CLIENT_ID for the browser build
# VITE_GOOGLE_CLIENT_ID=

# Optional: first superadmin bootstrap from the company control center.
# If a username does not exist locally yet, this portal can validate the
# submitted credentials against the company control center and create the
# local superadmin account automatically.
COMPANY_CONTROL_CENTER_BASE_URL=
# Optional explicit override if the company portal uses a different path.
# Default path on top of COMPANY_CONTROL_CENTER_BASE_URL:
# /api/customer-portals/bootstrap-login/
COMPANY_CONTROL_CENTER_BOOTSTRAP_LOGIN_URL=
# Optional shared secret header sent as X-Portal-Bootstrap-Secret
COMPANY_CONTROL_CENTER_BOOTSTRAP_SHARED_SECRET=
COMPANY_CONTROL_CENTER_BOOTSTRAP_TIMEOUT_SECONDS=10

# Optional: employee OCR runs as a separate service. Point this portal to the
# OCR service base URL, for example https://ocr.internal.example.com
# Local development default if left empty: http://127.0.0.1:8766
EMPLOYEE_OCR_SERVICE_URL=
EMPLOYEE_OCR_SERVICE_TIMEOUT_SECONDS=60
