# Leave empty to use Vite proxy to Django (same origin, session cookies work in dev)
VITE_API_BASE_URL=

# Same as backend GOOGLE_CLIENT_ID (OAuth 2.0 Web client ID from Google Cloud Console).
# Do not commit Google OAuth client-secret JSON files to the repo.
VITE_GOOGLE_CLIENT_ID=

# Optional Asprise Scanner production license code.
VITE_ASPRISE_SCANNERJS_LICENSE=
